version = 1

# Child configuration paths, relative to this grove.toml.
include = [
#   "REPLACE_WITH_CHILD_DIRECTORY/grove.toml",
]

# Add repositories below. Replace every REPLACE_WITH_* value, then uncomment
# one repo block for each repository you want grove to manage.

# Clone a repository with SSH.
# [repos.REPLACE_WITH_REPOSITORY_NAME]
# url = "git@github.com:REPLACE_WITH_OWNER/REPLACE_WITH_REPOSITORY.git"
# default_branch = "main" # Optional explicit override for origin/HEAD.

# Clone a repository into a custom local directory with HTTPS.
# [repos.REPLACE_WITH_REPOSITORY_NAME]
# path = "REPLACE_WITH_LOCAL_DIRECTORY"
# url = "https://github.com/REPLACE_WITH_OWNER/REPLACE_WITH_REPOSITORY.git"
# default_branch = "main" # Optional explicit override for origin/HEAD.
